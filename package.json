{
  "name": "cred402",
  "version": "1.0.0",
  "description": "x402-native TrustScore API for ERC-8004 AI agents",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node dist/db/migrate.js",
    "seed": "tsx src/indexers/seed.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "erc-8004",
    "trust-score",
    "ai-agents",
    "base"
  ],
  "author": "darrwalk",
